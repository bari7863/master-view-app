{
  "name": "master-view-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:worker": "esbuild scripts/crawl-worker.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/worker/crawl-worker.cjs --external:playwright --external:playwright-core --external:pdf-parse",
